{
  "name": "hms",
  "version": "0.1.0",
  "private": true,
  "description": "Hotel Management System — 20-room front desk (LAN, self-hosted)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "test": "npm run test --workspace server",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace web",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
