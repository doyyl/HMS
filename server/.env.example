# Copy to server/.env and adjust.
PORT=4000

# 'development' (default) or 'production'. In production the server refuses to
# boot unless JWT_SECRET is a strong, non-default value (>=16 chars).
NODE_ENV=development

# pino log level: trace|debug|info|warn|error. Defaults: debug in dev, info in prod.
# LOG_LEVEL=info

JWT_SECRET=change-me-to-a-long-random-secret

# --- Web / CORS ---------------------------------------------------------
# Comma-separated allowlist of browser origins allowed to call the API.
# Leave blank in dev (any origin reflected). Set in prod, e.g.:
#   CORS_ORIGINS=https://hotel.example.com,https://www.hotel.example.com
# CORS_ORIGINS=
# Public base URL of this deployment (used for payment return URLs).
# PUBLIC_BASE_URL=https://hotel.example.com

# --- Database (Supabase Postgres) ---------------------------------------
# Supabase → Project Settings → Database → Connection string → "Transaction"
# pooler (port 6543). Example:
#   postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres@127.0.0.1:5432/hms

# --- Slip image storage (Supabase Storage) ------------------------------
# Leave SUPABASE_URL blank to store slips on local disk (dev only).
# Create a PRIVATE bucket named "slips" first.
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role_key>   # server-only secret — never ship to the frontend
# SUPABASE_BUCKET=slips

# UPLOADS_DIR=/absolute/path   # local-disk fallback location
